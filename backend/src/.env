# Database
MONGO_URI=mongodb://mongo:27017/ollama_chat

# JWT
JWT_SECRET=secret_key
JWT_EXPIRES_IN=60m

# Server
PORT=3000

# Ollama
OLLAMA_URL=http://host.docker.internal:11434/api/generate


# Model Routing Configurations
OLLAMA_ROUTER_MODEL=mistral
OLLAMA_GENERAL_MODEL=gemma3
OLLAMA_CODING_MODEL=gemma4
OLLAMA_REASONING_MODEL=gemma4

# Chat
CHAT_TITLE_LENGTH=30
BCRYPT_ROUNDS=10
